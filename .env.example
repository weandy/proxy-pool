# ─── 登录账号 ───
ADMIN_USER=admin
ADMIN_PASS=change_me_to_a_strong_password

# ─── 安全密钥 ───
# JWT 签名密钥（请用 openssl rand -hex 32 生成）
JWT_SECRET=your_jwt_secret_here
# Go 引擎内部通信密钥（请用 openssl rand -hex 32 生成，须与 JWT_SECRET 不同）
INTERNAL_KEY=your_internal_key_here

# ─── 服务端口 ───
ADMIN_PORT=9090
ADMIN_HOST=0.0.0.0
